local shootButtonGui = nil
local shootButton = nil
local isSpamming = false

local function HasPistol(player)
    if not player then return false end
    local char = player.Character
    local bp = player:FindFirstChild("Backpack")
    if char then
        for _, t in ipairs(char:GetChildren()) do
            if t:IsA("Tool") and (t.Name:lower():find("gun") or t.Name:lower():find("revolver") or t.Name:lower():find("pistol")) then
                return true
            end
        end
    end
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if t:IsA("Tool") and (t.Name:lower():find("gun") or t.Name:lower():find("revolver") or t.Name:lower():find("pistol")) then
                return true
            end
        end
    end
    return false
end

local remotes = ReplicatedStorage:WaitForChild("Remotes", 5)
if remotes then
    local gameplay = remotes:WaitForChild("Gameplay", 5)
    if gameplay then
        local playerDataEvent = gameplay:WaitForChild("PlayerDataChanged", 5)
        if playerDataEvent then
            playerDataEvent.OnClientEvent:Connect(function(data)
                playerData = data or {}
                for _, player in pairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer then
                        UpdatePlayerRole(player)
                    end
                end
            end)
        end
    end
end

local function GetRoleFromPlayerData(player)
    if not playerData then return nil end
    local data = playerData[player.Name]
    if data and data.Role then return data.Role end
    return nil
end

local function GetRoleFromTools(player)
    local char = player.Character
    local bp = player:FindFirstChild("Backpack")
    if char and char:FindFirstChild("Knife") then return "Murderer" end
    if char and char:FindFirstChild("Gun") then return "Sheriff" end
    if bp and bp:FindFirstChild("Knife") then return "Murderer" end
    if bp and bp:FindFirstChild("Gun") then return "Sheriff" end
    return nil
end

function GetRole(player)
    local role = GetRoleFromPlayerData(player)
    if role then return role end
    role = GetRoleFromTools(player)
    if role then return role end
    if player.Character then
        local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid.Health > 0 then
            for name, data in pairs(playerData) do
                if data.Role == "Murderer" or data.Role == "Sheriff" or data.Role == "Hero" then
                    return "Innocent"
                end
            end
        end
    end
    return "Unknown"
end

function UpdatePlayerRole(player)
    local success, newRole = pcall(GetRole, player)
    if not success then return PlayerRoles[player] or "Unknown" end
    local oldRole = PlayerRoles[player]
    if newRole ~= oldRole then
        PlayerRoles[player] = newRole
    end
    return newRole
end

task.spawn(function()
    while true do
        local currentPing = 0.05
        pcall(function()
            currentPing = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
        end)

        table.insert(PingHistory, 1, currentPing)
        while #PingHistory > 10 do table.remove(PingHistory) end

        local sum = 0
        for _, v in ipairs(PingHistory) do sum = sum + v end
        EstimatedPing = #PingHistory > 0 and (sum / #PingHistory) or 0.05

        task.wait(0.05)
    end
end)

RunService.Heartbeat:Connect(function()
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char then continue end

        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        if not VelocityHistory[player] then
            VelocityHistory[player] = {}
        end

        table.insert(VelocityHistory[player], 1, root.AssemblyLinearVelocity)
        while #VelocityHistory[player] > 5 do
            table.remove(VelocityHistory[player])
        end
    end
end)

local function GetFilteredVelocity(player, rawVelocity)
    if not Config.OverdrivePrediction.PredictLag then return rawVelocity end
    local history = VelocityHistory[player]
    if not history or #history == 0 then return rawVelocity end

    local sum = Vector3.zero
    for _, vel in ipairs(history) do
        sum = sum + vel
    end
    return sum / #history
end

local function GetPrediction(target)
    if not target or not target.Character then return nil end
    local char = target.Character
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not root or not hum or hum.Health <= 0 then return nil end

    local currentPos = root.Position
    local velocity = GetFilteredVelocity(target, root.AssemblyLinearVelocity)

    local dt = Config.OverdrivePrediction.PredictionInterval
    if Config.OverdrivePrediction.PrioritizePing then
        dt = dt + EstimatedPing
    end
    dt = math.min(dt, Config.OverdrivePrediction.SimulationTimer)

    local horizontalVel = Vector3.new(velocity.X, 0, velocity.Z) * Config.OverdrivePrediction.HorizontalMultiplier
    local verticalVelY = velocity.Y * Config.OverdrivePrediction.VerticalMultiplier

    local predictedHorizontal = currentPos + (horizontalVel * dt)
    local predictedY = currentPos.Y + (verticalVelY * dt)

    if Config.OverdrivePrediction.PredictJump then
        local state = hum:GetState()
        if state == Enum.HumanoidStateType.Jumping or state == Enum.HumanoidStateType.Freefall then
            predictedY = predictedY - (0.5 * Config.OverdrivePrediction.Gravity * dt * dt)
        end
    end

    local finalPos = Vector3.new(predictedHorizontal.X, predictedY, predictedHorizontal.Z)
    finalPos = finalPos + Config.OverdrivePrediction.PositionOffset

    return finalPos
end

local function GetSATarget()
    if not HasPistol(LocalPlayer) then return nil end

    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end

    local bestTarget = nil
    local bestScore = -math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not player.Character then continue end

        local role = PlayerRoles[player] or "Unknown"
        local rolePriority = {
            Murderer = 1000,
            Sheriff = 800,
            Hero = 600,
            Innocent = 100,
            Unknown = 50
        }

        local root = player.Character:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        local distance = (root.Position - myHRP.Position).Magnitude
        local velocity = root.AssemblyLinearVelocity.Magnitude

        local score = (rolePriority[role] or 0)
            - (distance * 0.05)
            - (velocity * 1)

        if score > bestScore then
            bestScore = score
            bestTarget = player
        end
    end

    return bestTarget
end

local function Shoot(gunTool, target)
    if not gunTool or not target then return false end

    local char = LocalPlayer.Character
    if not char then return false end

    local hand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm") or char.PrimaryPart
    if not hand then return false end

    local pred = GetPrediction(target)
    if not pred then return false end

    local args = {
        CFrame.new(hand.Position),
        CFrame.new(pred)
    }

    local shoot = gunTool:FindFirstChild("Shoot")
    if shoot and shoot:IsA("RemoteEvent") then
        pcall(function()
            shoot:FireServer(unpack(args))
        end)
        return true
    end

    return false
end

local function StartSpamShooting(initialTarget)
    if isSpamming then return end

    isSpamming = true

    local char = LocalPlayer.Character
    if not char then isSpamming = false return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then isSpamming = false return end

    local gunTool, wasEquipped = nil, false
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") and (t.Name:lower():find("gun") or t.Name:lower():find("revolver") or t.Name:lower():find("pistol")) then
            gunTool = t
            wasEquipped = true
            break
        end
    end
    if not gunTool then
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if bp then
            for _, t in ipairs(bp:GetChildren()) do
                if t:IsA("Tool") and (t.Name:lower():find("gun") or t.Name:lower():find("revolver") or t.Name:lower():find("pistol")) then
                    gunTool = t
                    break
                end
            end
        end
    end
    if not gunTool then isSpamming = false return end

    if not wasEquipped then
        hum:EquipTool(gunTool)
        task.wait(0.1)
    end

    if shootButton then
        shootButton.Text = "FIRING!!!"
        shootButton.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    end

    local startTime = tick()
    local currentTarget = initialTarget

    task.spawn(function()
        while tick() - startTime < Config.Spam.Duration do
            if not isSpamming then break end

            if Config.Spam.TrackTarget then
                local newTarget = GetSATarget()
                if newTarget then
                    currentTarget = newTarget
                end
            end

            Shoot(gunTool, currentTarget)
            task.wait(Config.Spam.Interval)
        end

        isSpamming = false

        if shootButton then
            shootButton.Text = "SHOOT"
            shootButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        end

        if not wasEquipped then
            pcall(function() hum:UnequipTools() end)
        end
    end)
end

local function StopSpamShooting()
    isSpamming = false
    if shootButton then
        shootButton.Text = "SHOOT"
        shootButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    end
end

local function CleanupPlayer(player)
    local esp = ESPObjects[player]
    if esp then
        if esp.Highlight then esp.Highlight:Destroy() end
        ESPObjects[player] = nil
    end
    PlayerRoles[player] = nil
    VelocityHistory[player] = nil
end

local function CreateESP(player)
    if player == LocalPlayer then return nil end
    local esp = {}

    local highlight = Instance.new("Highlight")
    highlight.Name = "MM2_ESP"
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.FillTransparency = Config.ESP.FillTransparency
    highlight.OutlineTransparency = Config.ESP.OutlineTransparency
    highlight.Enabled = false
    esp.Highlight = highlight

    ESPObjects[player] = esp
    return esp
end

local function UpdateESP()
    if not Config.ESP.Enabled then
        for _, esp in pairs(ESPObjects) do
            if esp.Highlight then esp.Highlight.Enabled = false end
        end
        return
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local character = player.Character
        if not character then 
            local esp = ESPObjects[player]
            if esp then
                if esp.Highlight then esp.Highlight.Enabled = false end
            end
            continue 
        end
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then 
            local esp = ESPObjects[player]
            if esp then
                if esp.Highlight then esp.Highlight.Enabled = false end
            end
            continue 
        end

        local esp = ESPObjects[player]
        if not esp then esp = CreateESP(player) end

        if esp.Highlight.Parent ~= character then
            esp.Highlight.Parent = character
        end

        local role = PlayerRoles[player] or "Unknown"
        local color = Config.ESP.Colors[role] or Config.ESP.Colors.Unknown

        esp.Highlight.FillColor = color
        esp.Highlight.OutlineColor = color
        esp.Highlight.FillTransparency = Config.ESP.FillTransparency
        esp.Highlight.OutlineTransparency = Config.ESP.OutlineTransparency
        esp.Highlight.Enabled = true
    end

    for player in pairs(ESPObjects) do
        if not player.Parent then
            CleanupPlayer(player)
        end
    end
end

local function makeDraggable(button)
    local dragging = false
    local dragInput, dragStart, startPos

    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = button.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    button.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            button.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

local function CreateShootButton()
    if shootButtonGui then return end

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "MM2_ShootButton"
    screenGui.ResetOnSpawn = false
    screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

    local button = Instance.new("TextButton")
    button.Name = "ShootBtn"
    button.Size = Config.Button.Size
    button.Position = Config.Button.Position
    button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    button.BackgroundTransparency = 0.2
    button.Text = "SHOOT"
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.TextSize = 18
    button.Font = Enum.Font.GothamBlack
    button.AutoButtonColor = false
    button.Parent = screenGui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = button

    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 3
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Color = Color3.fromRGB(255, 50, 50)
    stroke.Parent = button

    button.MouseEnter:Connect(function()
        if not isSpamming then
            TweenService:Create(button, TweenInfo.new(0.2), {Size = UDim2.fromOffset(164, 58)}):Play()
        end
        stroke.Color = Color3.fromRGB(255, 100, 100)
    end)

    button.MouseLeave:Connect(function()
        if not isSpamming then
            TweenService:Create(button, TweenInfo.new(0.2), {Size = Config.Button.Size}):Play()
        end
        stroke.Color = Color3.fromRGB(255, 50, 50)
    end)

    button.MouseButton1Click:Connect(function()
        if isSpamming then
            StopSpamShooting()
        else
            local target = GetSATarget()
            if target then
                StartSpamShooting(target)
            end
        end
    end)

    makeDraggable(button)
    shootButtonGui = screenGui
    shootButton = button
end

CreateShootButton()

