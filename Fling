local selectedPlayer = nil

local function updateList()
	for _, child in ipairs(DropdownScroll:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1, 0, 0, 30)
			btn.BackgroundTransparency = 1
			btn.Text = "  " .. player.DisplayName .. " (@" .. player.Name .. ")"
			btn.TextColor3 = Color3.fromRGB(255, 255, 255)
			btn.TextSize = 14
			btn.TextXAlignment = Enum.TextXAlignment.Left
			btn.Font = Enum.Font.SourceSans
			btn.ZIndex = 6
			btn.Parent = DropdownScroll

			btn.MouseButton1Click:Connect(function()
				selectedPlayer = player
				DropdownBtn.Text = player.DisplayName .. " ▼"
				DropdownScroll.Visible = false
			end)
		end
	end
	DropdownScroll.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y)
end

DropdownBtn.MouseButton1Click:Connect(function()
	DropdownScroll.Visible = not DropdownScroll.Visible
	if DropdownScroll.Visible then
		updateList()
	end
end)

Players.PlayerAdded:Connect(updateList)
Players.PlayerRemoving:Connect(function(player)
	if selectedPlayer == player then
		selectedPlayer = nil
		DropdownBtn.Text = "Выберите цель ▼"
	end
	updateList()
end)

local function resetVelocity(root)
	if root then
		root.Velocity = Vector3.new(0, 0, 0)
		root.RotVelocity = Vector3.new(0, 0, 0)
		root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
		root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
	end
end

local function executeFling(targetPlayer)
	if not targetPlayer then return end
	local targetChar = targetPlayer.Character
	local myChar = LocalPlayer.Character
	if not targetChar or not myChar then return end

	local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
	local myRoot = myChar:FindFirstChild("HumanoidRootPart")
	if not targetRoot or not myRoot then return end

	DropdownScroll.Visible = false

	local oldPos = myRoot.CFrame
	resetVelocity(myRoot)

	local bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.Velocity = Vector3.new(0, 0, 0)
	bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
	bodyVelocity.Parent = myRoot

	local bodyAngularVelocity = Instance.new("BodyAngularVelocity")
	bodyAngularVelocity.AngularVelocity = Vector3.new(0, 12000, 0)
	bodyAngularVelocity.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
	bodyAngularVelocity.Parent = myRoot

	local flingTime = 1.8
	local startTime = tick()

	local connection
	connection = RunService.Heartbeat:Connect(function()
		if tick() - startTime > flingTime or not targetRoot.Parent or not myRoot.Parent then
			connection:Disconnect()
			bodyVelocity:Destroy()
			bodyAngularVelocity:Destroy()
			
			resetVelocity(myRoot)
			myRoot.CFrame = oldPos
			resetVelocity(myRoot)
			
			task.delay(3, function()
				if myRoot and myRoot.Parent then
					local distance = (myRoot.Position - oldPos.Position).Magnitude
					if distance >= 10 then
						resetVelocity(myRoot)
						myRoot.CFrame = oldPos
						resetVelocity(myRoot)
					end
				end
			end)
			return
		end

		local yOscillation = math.sin(tick() * 60) * 1.2
		myRoot.CFrame = targetRoot.CFrame * CFrame.new(0.1, yOscillation, 0.1)
		myRoot.Velocity = Vector3.new(20000, 20000, 20000)
	end)
end

FlingButton.MouseButton1Click:Connect(function()
	executeFling(selectedPlayer)
end)

local function findRoles()
	local murder, sheriff = nil, nil
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			local char = player.Character
			local backpack = player:FindFirstChild("Backpack")
			
			local hasKnife = false
			local hasRevolver = false
			
			if char then
				if char:FindFirstChild("Knife") then hasKnife = true end
				if char:FindFirstChild("Gun") or char:FindFirstChild("Revolver") then hasRevolver = true end
			end
			if backpack then
				if backpack:FindFirstChild("Knife") then hasKnife = true end
				if backpack:FindFirstChild("Gun") or backpack:FindFirstChild("Revolver") then hasRevolver = true end
			end
			
			if hasKnife then murder = player end
			if hasRevolver then sheriff = player end
		end
	end
	return murder, sheriff
end

FlingMurderBtn.MouseButton1Click:Connect(function()
	local murder, _ = findRoles()
	if murder then
		executeFling(murder)
	end
end)

FlingSheriffBtn.MouseButton1Click:Connect(function()
	local _, sheriff = findRoles()
	if sheriff then
		executeFling(sheriff)
	end
end)
