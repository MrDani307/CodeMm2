local function GetNPCs()
    local npcs = {}
    local rigs = Workspace:FindFirstChild("Rigs")
    if rigs then
        for _, model in ipairs(rigs:GetChildren()) do
            if model:IsA("Model") and model:FindFirstChild("Humanoid") and model:FindFirstChild("HumanoidRootPart") then
                table.insert(npcs, model)
            end
        end
    end
    local npcFolder = Workspace:FindFirstChild("NPCs")
    if npcFolder then
        for _, model in ipairs(npcFolder:GetChildren()) do
            if model:IsA("Model") and model:FindFirstChild("Humanoid") and model:FindFirstChild("HumanoidRootPart") then
                table.insert(npcs, model)
            end
        end
    end
    for _, model in ipairs(Workspace:GetChildren()) do
        if model:IsA("Model") and model:FindFirstChild("Humanoid") and model:FindFirstChild("HumanoidRootPart") then
            local isPlayer = false
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr.Character == model then
                    isPlayer = true
                    break
                end
            end
            if not isPlayer then
                local already = false
                for _, n in ipairs(npcs) do if n == model then already = true break end end
                if not already then table.insert(npcs, model) end
            end
        end
    end
    return npcs
end

local function GetSATarget()
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    if not HasPistol(LocalPlayer) then return nil end
    local closest, closestDist = nil, math.huge

    -- DUEL MODE: target nearest player regardless of role/weapon
    if ESPConfig.DuelMode then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer then continue end
            if not plr.Character then continue end
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            local d = (root.Position - myRoot.Position).Magnitude
            if d < closestDist then closestDist = d closest = plr end
        end
        return closest
    end

    if ESPConfig.TrainingMode then
        for _, npc in ipairs(GetNPCs()) do
            local root = npc:FindFirstChild("HumanoidRootPart")
            if root then
                local d = (root.Position - myRoot.Position).Magnitude
                if d < closestDist then closestDist = d closest = npc end
            end
        end
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer then continue end
            if not plr.Character then continue end
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            local d = (root.Position - myRoot.Position).Magnitude
            if d < closestDist then closestDist = d closest = plr end
        end
    else
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer then continue end
            if not plr.Character then continue end
            if not HasWeapon(plr) then continue end
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            local d = (root.Position - myRoot.Position).Magnitude
            if d < closestDist then closestDist = d closest = plr end
        end
    end
    return closest
end

local function GetSAPrediction(target)
    if not target then return nil end
    local isNPC = typeof(target) == "Instance" and not target:IsA("Player")
    local character = isNPC and target or target.Character
    if not character then return nil end
    local root = character:FindFirstChild("HumanoidRootPart")
    local hum = character:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return nil end

    local ping = 0.1
    pcall(function()
        ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
    end)
    local t = ping + 0.03

    local currentPos = root.Position
    local currentVel = root.AssemblyLinearVelocity

    local historyKey = isNPC and target or target.UserId
    local history = TargetHistory[historyKey] or {lastVel = currentVel, lastTime = tick()}
    local now = tick()
    local dt = math.max(now - history.lastTime, 0.016)
    local acceleration = (currentVel - history.lastVel) / dt

    TargetHistory[historyKey] = {lastVel = currentVel, lastTime = now}

    local gravity = (hum:GetState() == Enum.HumanoidStateType.Freefall or hum:GetState() == Enum.HumanoidStateType.Jumping) and Workspace.Gravity or 0

    local predX = currentPos.X + (currentVel.X * t) + (0.5 * acceleration.X * (t ^ 2))
    local predY = currentPos.Y + (currentVel.Y * t) + (0.5 * (acceleration.Y - gravity) * (t ^ 2))
    local predZ = currentPos.Z + (currentVel.Z * t) + (0.5 * acceleration.Z * (t ^ 2))
    local predictedPos = Vector3.new(predX, predY, predZ)

    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {character, LocalPlayer.Character}
    local groundCheck = Workspace:Raycast(predictedPos + Vector3.new(0, 8, 0), Vector3.new(0, -16, 0), raycastParams)
    if groundCheck then
        local floorY = groundCheck.Position.Y + (root.Size.Y / 2)
        if predictedPos.Y < floorY then
            predictedPos = Vector3.new(predictedPos.X, floorY, predictedPos.Z)
        end
    end

    return predictedPos
end

-- ==================== WALL CHECK ====================
local function IsTargetVisible(target)
    if not ESPConfig.WallCheck then return true end

    local char = LocalPlayer.Character
    if not char then return false end

    local rightHand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm")
    if not rightHand then return false end

    local isNPC = typeof(target) == "Instance" and not target:IsA("Player")
    local character = isNPC and target or target.Character
    if not character then return false end

    local targetPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
    if not targetPart then return false end

    local origin = rightHand.Position
    local destination = targetPart.Position
    local direction = destination - origin

    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {char, character}
    raycastParams.IgnoreWater = true

    local result = Workspace:Raycast(origin, direction, raycastParams)
    return result == nil
end

-- ==================== COMBAT HELPERS ====================
local function getPredictedPosition(player, offset)
    local char = player.Character
    if not char then return Vector3.new(0,0,0) end
    local hrp = char:FindFirstChild("UpperTorso") or char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return hrp and hrp.Position or Vector3.new(0,0,0) end

    local velocity = hrp.AssemblyLinearVelocity
    local moveDir = hum.MoveDirection
    local predicted = hrp.Position + ((velocity * Vector3.new(0.75, 0.5, 0.75))) * (offset / 15) + moveDir * offset
    return predicted
end

-- ==================== INSTAKILL (FROM YARHM) ====================
-- Instakill shoots directly at the target's current position without prediction
-- This bypasses movement-based anti-cheats that detect prediction
local function InstaKillShoot()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    -- Find target (murderer or nearest player with weapon)
    local target = nil
    
    -- First try to find murderer
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and GetRole(plr) == "Murderer" then
            target = plr
            break
        end
    end
    
    -- Fallback to nearest player with weapon
    if not target then
        target = GetSATarget()
    end
    
    if not target then return end

    -- Wall Check
    if ESPConfig.WallCheck and not IsTargetVisible(target) then
        return
    end

    -- Get target character and HRP
    local targetChar = target.Character
    if not targetChar then return end
    local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return end

    -- Now find and equip gun
    local gunTool, wasEquipped = nil, false
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") and (t.Name:lower():find("gun") or t.Name:lower():find("revolver") or t.Name:lower():find("pistol")) then
            gunTool = t
            wasEquipped = true
            break
        end
    end
    if not gunTool then
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if bp then
            for _, t in ipairs(bp:GetChildren()) do
                if t:IsA("Tool") and (t.Name:lower():find("gun") or t.Name:lower():find("revolver") or t.Name:lower():find("pistol")) then
                    gunTool = t
                    break
                end
            end
        end
    end
    if not gunTool then return end

    if not wasEquipped then
        hum:EquipTool(gunTool)
        task.wait(0.12)
    end

    -- INSTAKILL: Shoot directly at target position (no prediction)
    -- Using YARHM's method: origin slightly above target, destination at target
    local instaPos = targetHRP.Position
    local args = {
        CFrame.new(instaPos + Vector3.new(0, 1, 0)), -- origin slightly above
        CFrame.new(instaPos) -- destination at target
    }

    task.spawn(function()
        local shoot = gunTool:FindFirstChild("Shoot")
        if shoot then
            pcall(function() shoot:FireServer(unpack(args)) end)
        else
            -- Fallback to other methods
            local remote = gunTool:FindFirstChild("KnifeLocal") and gunTool.KnifeLocal:FindFirstChild("CreateBeam") and gunTool.KnifeLocal.CreateBeam:FindFirstChild("RemoteFunction")
            if remote then
                pcall(function() remote:InvokeServer(1, instaPos, "AH2") end)
            else
                pcall(function() gunTool:Activate() end)
            end
        end
        task.wait(0.15)
        if not wasEquipped then pcall(function() hum:UnequipTools() end) end
    end)
end

-- ==================== ORIGINAL SAShoot (with instakill support) ====================
local function SAShoot()
    -- If instakill mode is enabled, use InstaKillShoot instead
    if ESPConfig.Instakill then
        InstaKillShoot()
        return
    end

    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    -- Check target FIRST before equipping anything
    local target = GetSATarget()
    if not target then return end

    -- Wall Check: if enabled and target is behind wall, do nothing (don't equip gun)
    if ESPConfig.WallCheck and not IsTargetVisible(target) then
        return
    end

    -- Now find and equip gun
    local gunTool, wasEquipped = nil, false
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") and (t.Name:lower():find("gun") or t.Name:lower():find("revolver") or t.Name:lower():find("pistol")) then
            gunTool = t
            wasEquipped = true
            break
        end
    end
    if not gunTool then
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if bp then
            for _, t in ipairs(bp:GetChildren()) do
                if t:IsA("Tool") and (t.Name:lower():find("gun") or t.Name:lower():find("revolver") or t.Name:lower():find("pistol")) then
                    gunTool = t
                    break
                end
            end
        end
    end
    if not gunTool then return end

    if not wasEquipped then
        hum:EquipTool(gunTool)
        task.wait(0.12)
    end

    local pred = GetSAPrediction(target)
    if not pred then
        if not wasEquipped then hum:UnequipTools() end
        return
    end

    task.spawn(function()
        local gunServer = gunTool:FindFirstChild("GunServer")
        if gunServer then
            local shootStart = gunServer:FindFirstChild("ShootStart")
            if shootStart and shootStart:IsA("RemoteEvent") then
                pcall(function() shootStart:FireServer(pred) end)
                task.wait(0.15)
                if not wasEquipped then pcall(function() hum:UnequipTools() end) end
                return
            end
        end
        local remote = gunTool:FindFirstChild("KnifeLocal") and gunTool.KnifeLocal:FindFirstChild("CreateBeam") and gunTool.KnifeLocal.CreateBeam:FindFirstChild("RemoteFunction")
        if remote then
            pcall(function() remote:InvokeServer(1, pred, "AH2") end)
        else
            local shoot = gunTool:FindFirstChild("Shoot")
            if shoot then
                local hand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm") or char:FindFirstChild("LeftHand") or char.PrimaryPart
                if hand then
                    pcall(function() shoot:FireServer(CFrame.new(hand.Position), CFrame.new(pred)) end)
                end
            else
                pcall(function() gunTool:Activate() end)
            end
        end
        task.wait(0.15)
        if not wasEquipped then pcall(function() hum:UnequipTools() end) end
    end)
end

local function knifeThrow(silent)
    local myRole = GetRole(LocalPlayer)
    if myRole ~= "Murderer" then 
        if not silent then
            -- notify removed
        end
        return 
    end

    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    if not char:FindFirstChild("Knife") then
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if bp and bp:FindFirstChild("Knife") then
            hum:EquipTool(bp.Knife)
        else
            if not silent then
                -- notify removed
            end
            return
        end
    end

    local nearest = findNearestPlayer()
    if not nearest or not nearest.Character then
        if not silent then
            -- notify removed
        end
        return
    end

    local nearestHRP = nearest.Character:FindFirstChild("HumanoidRootPart")
    if not nearestHRP then
        if not silent then
            -- notify removed
        end
        return
    end

    local targetPos = GetSAPrediction(nearest)
    if not targetPos then
        targetPos = getPredictedPosition(nearest, 2.8 + 1)
    end

    local argsThrowRemote = {
        CFrame.new(char.RightHand.Position),
        CFrame.new(targetPos),
    }

    local knife = char:WaitForChild("Knife")
    local events = knife:WaitForChild("Events")
    local thrown = events:WaitForChild("KnifeThrown")
    thrown:FireServer(unpack(argsThrowRemote))
end

-- ==================== FLOATING BUTTONS ====================
local function makeDraggable(button)
    local dragging = false
    local dragInput, dragStart, startPos

    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = button.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    button.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            button.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

local function spinGradient(gradient, duration)
    task.spawn(function()
        while gradient.Parent do
            local startTick = os.clock()
            while os.clock() - startTick < duration and gradient.Parent do
                gradient.Rotation = ((os.clock() - startTick) / duration) * 360
                RunService.Heartbeat:Wait()
            end
        end
    end)
end

