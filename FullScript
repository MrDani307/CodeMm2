local function SetupPlayerTracking(player)
    if player == LocalPlayer then return end
    local function onCharacterAdded(character)
        UpdatePlayerRole(player)
        character.ChildAdded:Connect(function(child)
            if child.Name == "Knife" or child.Name == "Gun" then UpdatePlayerRole(player) end
        end)
        character.ChildRemoved:Connect(function(child)
            if child.Name == "Knife" or child.Name == "Gun" then UpdatePlayerRole(player) end
        end)
    end
    if player.Character then onCharacterAdded(player.Character) end
    player.CharacterAdded:Connect(onCharacterAdded)
    player.CharacterRemoving:Connect(function() PlayerRoles[player] = "Unknown" end)

    local bp = player:FindFirstChild("Backpack")
    if bp then
        bp.ChildAdded:Connect(function(child)
            if child.Name == "Knife" or child.Name == "Gun" then UpdatePlayerRole(player) end
        end)
        bp.ChildRemoved:Connect(function(child)
            if child.Name == "Knife" or child.Name == "Gun" then UpdatePlayerRole(player) end
        end)
    end
    player.ChildAdded:Connect(function(child)
        if child.Name == "Backpack" then
            child.ChildAdded:Connect(function(tool)
                if tool.Name == "Knife" or tool.Name == "Gun" then UpdatePlayerRole(player) end
            end)
        end
    end)
end

for _, player in pairs(Players:GetPlayers()) do
    SetupPlayerTracking(player)
end
Players.PlayerAdded:Connect(SetupPlayerTracking)

RunService.RenderStepped:Connect(UpdateESP)

-- Cleanup TargetHistory for disconnected players
task.spawn(function()
    while true do
        task.wait(10)
        for key, _ in pairs(TargetHistory) do
            local found = false
            if typeof(key) == "number" then
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr.UserId == key then
                        found = true
                        break
                    end
                end
            elseif typeof(key) == "Instance" then
                found = key.Parent ~= nil
            end
            if not found then
                TargetHistory[key] = nil
            end
        end
    end
end)

