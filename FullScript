local function CreateObjectESP(object, color, labelText)
    if not object or not object.Parent then return nil end
    if ObjectESP[object] then return ObjectESP[object] end

    local esp = {}
    local highlight = Instance.new("Highlight")
    highlight.Name = "MM2_ESP_Object"
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.FillTransparency = ESPConfig.FillTransparency
    highlight.OutlineTransparency = ESPConfig.OutlineTransparency
    highlight.FillColor = color
    highlight.OutlineColor = color
    highlight.Adornee = object
    highlight.Parent = object
    esp.Highlight = highlight

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "MM2_ESP_Billboard_Object"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 2, 0)

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Name = "Name"
    nameLabel.Size = UDim2.new(1, 0, 1, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 14
    nameLabel.Text = labelText
    nameLabel.TextColor3 = color
    nameLabel.Parent = billboard

    local targetPart = object:IsA("BasePart") and object or object:FindFirstChildWhichIsA("BasePart")
    if targetPart then
        billboard.Adornee = targetPart
        billboard.Parent = targetPart
    end

    esp.Billboard = billboard
    esp.Object = object
    ObjectESP[object] = esp
    return esp
end

local function RemoveObjectESP(object)
    local esp = ObjectESP[object]
    if esp then
        if esp.Highlight and esp.Highlight.Parent then esp.Highlight:Destroy() end
        if esp.Billboard and esp.Billboard.Parent then esp.Billboard:Destroy() end
        ObjectESP[object] = nil
    end
end

local function ClearObjectESP()
    for object, _ in pairs(ObjectESP) do
        RemoveObjectESP(object)
    end
end

local function ScanExistingObjects()
    if ESPConfig.TrapESP then
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v.Name == "Trap" and (v.Parent:IsA("Folder") or v.Parent:IsA("Model")) then
                if not ObjectESP[v] then
                    pcall(function() v.Transparency = 0 end)
                    CreateObjectESP(v, ESPConfig.Colors.Trap, "[Trap]")
                end
            end
        end
    end
    if ESPConfig.GunDropESP then
        local gunDrop = Workspace:FindFirstChild("GunDrop", true)
        if gunDrop and not ObjectESP[gunDrop] then
            CreateObjectESP(gunDrop, ESPConfig.Colors.GunDrop, "[Gun Drop]")
        end
    end
end

local function AutoGetGun(gunDrop)
    if not ESPConfig.AutoGetGun then return end
    if not gunDrop or not gunDrop.Parent then return end

    -- notify removed
    task.spawn(function()
        task.wait(0.5)
        if not Workspace:FindFirstChild("GunDrop", true) then
            -- notify removed
            return
        end
        local char = LocalPlayer.Character
        if not char then return end
        local myRoot = char:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end

        if firetouchinterest then
            pcall(function()
                firetouchinterest(myRoot, gunDrop, 0)
                task.wait()
                firetouchinterest(myRoot, gunDrop, 1)
            end)
            -- notify removed
        else
            -- notify removed
        end
    end)
end

Workspace.DescendantAdded:Connect(function(descendant)
    if descendant.Name == "GunDrop" and ESPConfig.GunDropESP then
        CreateObjectESP(descendant, ESPConfig.Colors.GunDrop, "[Gun Drop]")
        -- notify removed
        AutoGetGun(descendant)
    end
    if descendant.Name == "Trap" and ESPConfig.TrapESP then
        if descendant.Parent:IsA("Folder") or descendant.Parent:IsA("Model") then
            pcall(function() descendant.Transparency = 0 end)
            CreateObjectESP(descendant, ESPConfig.Colors.Trap, "[Trap]")
            -- notify removed
        end
    end
end)

Workspace.DescendantRemoving:Connect(function(descendant)
    if descendant.Name == "GunDrop" or descendant.Name == "Trap" then
