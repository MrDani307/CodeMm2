-- ==================== NEAREST PLAYER HELPER (MOVED UP) ====================
local function findNearestPlayer()
    local nearestPlayer = nil
    local shortestDistance = math.huge
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local otherHRP = player.Character:FindFirstChild("HumanoidRootPart")
            if otherHRP then
                local dist = (myHRP.Position - otherHRP.Position).Magnitude
                if dist < shortestDistance then
                    shortestDistance = dist
                    nearestPlayer = player
                end
            end
        end
    end
    return nearestPlayer
end

-- ==================== ROLE DETECTION ====================
local function GetRoleFromPlayerData(player)
    if not playerData then return nil end
    local data = playerData[player.Name]
    if data and data.Role then return data.Role end
    return nil
end

local function GetRoleFromTools(player)
    local char = player.Character
    local bp = player:FindFirstChild("Backpack")
    if char and char:FindFirstChild("Knife") then return "Murderer" end
    if char and char:FindFirstChild("Gun") then return "Sheriff" end
    if bp and bp:FindFirstChild("Knife") then return "Murderer" end
    if bp and bp:FindFirstChild("Gun") then return "Sheriff" end
    return nil
end

function GetRole(player)
    -- DUEL MODE: nearest player is always Murderer
    if ESPConfig.DuelMode and player ~= LocalPlayer then
        local nearest = findNearestPlayer()
        if nearest == player then
            return "Murderer"
        end
    end

    local role = GetRoleFromPlayerData(player)
    if role then return role end
    role = GetRoleFromTools(player)
    if role then return role end
    if player.Character then
        local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid.Health > 0 then
            for name, data in pairs(playerData) do
                if data.Role == "Murderer" or data.Role == "Sheriff" or data.Role == "Hero" then
                    return "Innocent"
                end
            end
        end
    end
    return "Unknown"
end

local function UpdatePlayerRole(player)
    local success, newRole = pcall(GetRole, player)
    if not success then return PlayerRoles[player] or "Unknown" end
    local oldRole = PlayerRoles[player]
    if newRole ~= oldRole then
        PlayerRoles[player] = newRole
        if ESPConfig.ShowDebug and player ~= LocalPlayer then
            -- notify removed
        end
    end
    return newRole
end

