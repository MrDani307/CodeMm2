local function UpdateESP()
    if not ESPConfig.Enabled then
        for _, esp in pairs(ESPObjects) do
            if esp.Highlight then esp.Highlight.Enabled = false end
            if esp.Billboard then esp.Billboard.Enabled = false end
        end
        return
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local character = player.Character
        if not character then continue end
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local esp = ESPObjects[player]
        if not esp then esp = CreateESP(player) end

        local role = PlayerRoles[player] or "Unknown"
        local color = ESPConfig.Colors[role] or ESPConfig.Colors.Unknown

        if esp.Highlight.Parent ~= character then
            esp.Highlight.Parent = character
        end
        esp.Highlight.FillColor = color
        esp.Highlight.OutlineColor = color
        esp.Highlight.FillTransparency = ESPConfig.FillTransparency
        esp.Highlight.OutlineTransparency = ESPConfig.OutlineTransparency
        esp.Highlight.Enabled = true

        if esp.Billboard.Parent ~= hrp then
            esp.Billboard.Parent = hrp
        end
        esp.NameLabel.Text = player.DisplayName
        esp.NameLabel.TextColor3 = color
        esp.NameLabel.Visible = ESPConfig.ShowName
        esp.RoleLabel.Text = "[" .. role .. "]"
        esp.RoleLabel.TextColor3 = color
        esp.RoleLabel.Visible = ESPConfig.ShowRole
        esp.Billboard.Enabled = (ESPConfig.ShowName or ESPConfig.ShowRole)
        esp.Billboard.StudsOffset = Vector3.new(0, 3.5 + (hrp.Size.Y / 2), 0)
    end

    if ESPConfig.TrainingMode then
        for _, npc in ipairs(GetNPCs()) do
            local character = npc
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end

            local esp = ESPObjects[npc]
            if not esp then esp = CreateNPCESP(npc) end

            local color = Color3.fromRGB(255, 100, 50)

            if esp.Highlight.Parent ~= character then
                esp.Highlight.Parent = character
            end
            esp.Highlight.FillColor = color
            esp.Highlight.OutlineColor = color
            esp.Highlight.FillTransparency = ESPConfig.FillTransparency
            esp.Highlight.OutlineTransparency = ESPConfig.OutlineTransparency
            esp.Highlight.Enabled = true

            if esp.Billboard.Parent ~= hrp then
                esp.Billboard.Parent = hrp
            end
            esp.NameLabel.Text = npc.Name
            esp.NameLabel.TextColor3 = color
            esp.NameLabel.Visible = ESPConfig.ShowName
            esp.RoleLabel.Text = "[BOT]"
            esp.RoleLabel.TextColor3 = color
            esp.RoleLabel.Visible = ESPConfig.ShowRole
            esp.Billboard.Enabled = (ESPConfig.ShowName or ESPConfig.ShowRole)
            esp.Billboard.StudsOffset = Vector3.new(0, 3.5 + (hrp.Size.Y / 2), 0)
        end
    end

    for obj in pairs(ESPObjects) do
        if typeof(obj) == "Instance" and not obj:IsA("Player") then
            if not obj.Parent then
                CleanupNPC(obj)
            end
        elseif not obj.Parent then
            CleanupPlayer(obj)
        end
    end
end

